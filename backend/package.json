{
  "name": "backend",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./src/index.ts",
    "dev:debug": "bun --inspect-wait=6499 --watch ./src/index.ts",
    "start": "bun ./src/index.ts",
    "typeorm": "bun run ./node_modules/typeorm/cli.js",
    "migration:generate": "bun run typeorm migration:generate -d ./data_source.ts",
    "migration:create": "bun run typeorm migration:create ./data_source.ts",
    "migration:run": "bun run typeorm migration:run -d ./data_source.ts",
    "migration:revert": "bun run typeorm migration:revert -d ./data_source.ts",
    "migration:show": "bun run typeorm migration:show -d ./data_source.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/luxon": "3.7.1"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/openapi": "1.4.15",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "argon2": "0.44.0",
    "elysia": "1.4.28",
    "jose": "6.2.3",
    "luxon": "3.7.2",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "typeorm": "1.0.0",
    "uuid": "14.0.0"
  }
}
